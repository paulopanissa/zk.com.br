+// ─── Módulo 28: Vendas (PDV) ──────────────────────────────────────────────────
+
+enum VendaStatus {
+  ABERTA
+  FINALIZADA
+  CANCELADA
+}
+
+enum VendaOrigem {
+  PDV
+  ECOMMERCE
+  PDV_OFFLINE
+}
+
+enum VendaPaymentStatus {
+  PENDENTE
+  PAGO
+  CANCELADO
+}
+
+model Venda {
+  id                      String      @id @default(uuid())
+  unidade_id              String
+  numero                  Int         @default(autoincrement())
+  status                  VendaStatus @default(ABERTA)
+  origem                  VendaOrigem @default(PDV)
+  cliente_id              String?
+  desconto_total_centavos Int         @default(0)
+  total_bruto_centavos    Int         @default(0)
+  total_liquido_centavos  Int         @default(0)
+  observacao              String?     @db.Text
+  created_by              String
+  finalizada_em           DateTime?
+  cancelada_em            DateTime?
+  sync_id                 String?     @unique @db.VarChar(100)
+  created_at              DateTime    @default(now())
+  updated_at              DateTime    @updatedAt
+
+  unit     Unit           @relation(fields: [unidade_id], references: [id])
+  cliente  Customer?      @relation("CustomerVendas", fields: [cliente_id], references: [id])
+  items    VendaItem[]
+  payments VendaPayment[]
+
+  @@index([unidade_id, status])
+  @@index([unidade_id, created_at])
+  @@index([cliente_id])
+  @@map("vendas")
+}
+
+model VendaItem {
+  id                      String   @id @default(uuid())
+  venda_id                String
+  product_id              String
+  numero_item             Int
+  quantidade              Decimal  @db.Decimal(12, 3)
+  preco_unitario_centavos Int
+  desconto_item_centavos  Int      @default(0)
+  total_centavos          Int
+  created_at              DateTime @default(now())
+  updated_at              DateTime @updatedAt
+
+  venda   Venda   @relation(fields: [venda_id], references: [id], onDelete: Cascade)
+  product Product @relation("ProductVendaItems", fields: [product_id], references: [id])
+
+  @@index([venda_id])
+  @@index([product_id])
+  @@map("venda_items")
+}
+
+model VendaPayment {
+  id                      String             @id @default(uuid())
+  venda_id                String
+  metodo                  PaymentMethod
+  valor_centavos          Int
+  status                  VendaPaymentStatus @default(PENDENTE)
+  troco_centavos          Int                @default(0)
+  provider_transaction_id String?            @db.VarChar(255)
+  pago_em                 DateTime?
+  created_at              DateTime           @default(now())
+  updated_at              DateTime           @updatedAt
+
+  venda Venda @relation(fields: [venda_id], references: [id], onDelete: Cascade)
+
+  @@index([venda_id])
+  @@map("venda_payments")
+}
