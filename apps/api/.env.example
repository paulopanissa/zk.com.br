# App
PORT=3000
NODE_ENV=development

# Database (matches docker-compose defaults)
DATABASE_URL="postgresql://zk_user:zk_password@localhost:5432/zk_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# RabbitMQ
RABBITMQ_URL="amqp://zk_user:zk_password@localhost:5672"

# JWT (use strong random secret in production)
JWT_SECRET=changeme_use_a_strong_random_secret_in_production
JWT_EXPIRES_IN=7d
