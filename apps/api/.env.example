# App
PORT=3000
NODE_ENV=development

# Database (matches docker-compose defaults)
DATABASE_URL="postgresql://zk_user:zk_password@localhost:5432/zk_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# RabbitMQ
RABBITMQ_URL="amqp://zk_user:zk_password@localhost:5672"

# JWT — system realm (admin/PDV)
JWT_SYSTEM_SECRET=changeme_system_secret_minimum_32_chars_here
# JWT — ecommerce realm (customers) — separate secret, never cross realms
JWT_ECOMMERCE_SECRET=changeme_ecommerce_secret_minimum_32_chars
# TTL in seconds: 900 = 15min, 604800 = 7d
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# PII Encryption (AES-256-GCM) — used for credentials, webhook secrets, CPF/CNPJ
# PII_ENCRYPTION_KEY: 64 hex chars (32 bytes). Generate: openssl rand -hex 32
# PII_HASH_KEY: any strong string for HMAC-SHA256 searchable hashes
PII_ENCRYPTION_KEY=changeme_64_hex_chars_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PII_HASH_KEY=changeme_strong_hmac_key_here

# Storage — STORAGE_PROVIDER: local | s3 | r2 (no inline comments — dotenv does not strip them)
STORAGE_PROVIDER=local
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BUCKET=zk-dev
STORAGE_REGION=us-east-1
# R2 only: https://<account_id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=
# CDN base URL para mídias públicas (ex: https://cdn.example.com)
STORAGE_CDN_BASE_URL=
