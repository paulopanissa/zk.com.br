generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SystemRole {
  ADMINISTRADOR
  OPERADOR_ESTOQUE_COMPRAS
  OPERADOR_PDV
  DPO
}

enum TipoDocumento {
  CNPJ
  CPF
}

enum RegimeTributario {
  SIMPLES
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

enum TipoEmailEmpresa {
  COMERCIAL
  FINANCEIRO
  SUPORTE
  NFE
  DPO
  OUTRO
}

enum TipoTelefoneEmpresa {
  COMERCIAL
  FINANCEIRO
  SUPORTE
  WHATSAPP
  OUTRO
}

enum TipoEnderecoEmpresa {
  MATRIZ
  CORRESPONDENCIA
  COBRANCA
}

enum TipoUnidade {
  MATRIZ
  FILIAL
  PONTO_DE_VENDA_MOVEL
}

// ─── Auth / System Realm ───────────────────────────────────────────────────

model SystemUser {
  id            String     @id @default(uuid())
  email         String     @unique
  password_hash String
  name          String
  role          SystemRole
  unidade_id    String?
  is_active     Boolean    @default(true)
  last_login_at DateTime?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@map("system_users")
}

// ─── Módulo 14: Configurações da Empresa ─────────────────────────────────────

model CompanySettings {
  id                  String              @id @default(uuid())
  // Garante singleton: só uma linha pode existir (constraint de banco)
  singleton_key       String              @unique @default("SINGLETON")
  razao_social        String              @db.VarChar(255)
  nome_fantasia       String?             @db.VarChar(255)
  cnpj_cpf            String              @unique @db.VarChar(14)
  tipo_documento      TipoDocumento
  inscricao_estadual  String?             @db.VarChar(20)
  inscricao_municipal String?             @db.VarChar(20)
  regime_tributario   RegimeTributario
  logo_url            String?             @db.VarChar(500)
  site_url            String?             @db.VarChar(500)
  dpo_email           String?             @db.VarChar(255)
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  emails    CompanyEmail[]
  phones    CompanyPhone[]
  addresses CompanyAddress[]
  units     Unit[]

  @@map("company_settings")
}

model CompanyEmail {
  id                  String           @id @default(uuid())
  company_settings_id String
  tipo                TipoEmailEmpresa
  email               String           @db.VarChar(255)
  principal           Boolean          @default(false)

  company_settings CompanySettings @relation(fields: [company_settings_id], references: [id])

  @@map("company_emails")
}

model CompanyPhone {
  id                  String              @id @default(uuid())
  company_settings_id String
  tipo                TipoTelefoneEmpresa
  ddi                 String              @default("+55") @db.VarChar(5)
  numero              String              @db.VarChar(20)
  principal           Boolean             @default(false)

  company_settings CompanySettings @relation(fields: [company_settings_id], references: [id])

  @@map("company_phones")
}

model CompanyAddress {
  id                  String              @id @default(uuid())
  company_settings_id String
  tipo                TipoEnderecoEmpresa
  logradouro          String              @db.VarChar(255)
  numero              String              @db.VarChar(20)
  complemento         String?             @db.VarChar(100)
  bairro              String              @db.VarChar(100)
  municipio           String              @db.VarChar(100)
  uf                  String              @db.Char(2)
  cep                 String              @db.VarChar(8)
  codigo_ibge         String?             @db.VarChar(7)
  principal           Boolean             @default(false)

  company_settings CompanySettings @relation(fields: [company_settings_id], references: [id])

  @@map("company_addresses")
}

// ─── Módulo 15: Unidades / Lojas ─────────────────────────────────────────────

model Unit {
  id                    String      @id @default(uuid())
  company_settings_id   String
  nome                  String      @db.VarChar(255)
  slug                  String      @unique @db.VarChar(100)
  tipo                  TipoUnidade
  cnpj_inscricao        String?     @db.VarChar(20)
  ativa                 Boolean     @default(true)
  permite_venda_offline Boolean     @default(false)
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  company_settings CompanySettings @relation(fields: [company_settings_id], references: [id])
  address          UnitAddress?
  config           UnitConfig?
  brands                   Brand[]
  categories               Category[]
  suppliers                Supplier[]
  cost_centers             CostCenter[]
  cost_items               CostItem[]
  products                 Product[]              @relation("UnitProducts")
  lots                     Lot[]
  stock_movements          StockMovement[]
  customer_field_defs      CustomerFieldDefinition[]
  customers                Customer[]
  lgpd_requests            LgpdDataRequest[]          @relation("UnitLgpdRequests")
  nf_entradas              NfEntrada[]
  vendas                   Venda[]

  // DB-level: partial unique index on (company_settings_id) WHERE tipo = 'MATRIZ' AND ativa = true
  // Applied via raw migration: CREATE UNIQUE INDEX idx_one_matriz ON units (company_settings_id) WHERE tipo = 'MATRIZ' AND ativa = true;
  @@map("units")
}

model UnitAddress {
  id          String  @id @default(uuid())
  unit_id     String  @unique
  logradouro  String  @db.VarChar(255)
  numero      String  @db.VarChar(20)
  complemento String? @db.VarChar(100)
  bairro      String  @db.VarChar(100)
  municipio   String  @db.VarChar(100)
  uf          String  @db.Char(2)
  cep         String  @db.VarChar(8)
  codigo_ibge String? @db.VarChar(7)

  unit Unit @relation(fields: [unit_id], references: [id])

  @@map("unit_addresses")
}

model UnitConfig {
  id                      String  @id @default(uuid())
  unit_id                 String  @unique
  estoque_proprio         Boolean @default(true)
  caixa_proprio           Boolean @default(true)
  gateway_pdv_override_id String?
  timezone                String  @default("America/Sao_Paulo") @db.VarChar(50)

  unit Unit @relation(fields: [unit_id], references: [id])

  @@map("unit_configs")
}

// ─── Módulo 1: Marcas ─────────────────────────────────────────────────────────

model Brand {
  id               String   @id @default(uuid())
  unidade_id       String
  name             String   @db.VarChar(150)
  slug             String   @db.VarChar(160)
  logo_url         String?  @db.VarChar(512)
  logo_storage_key String?  @db.VarChar(512)
  active           Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  unit      Unit            @relation(fields: [unidade_id], references: [id])
  suppliers SupplierBrand[]
  products  Product[]
  nf_entrada_items NfEntradaItem[]

  @@unique([unidade_id, slug])
  @@map("brands")
}

// ─── Módulo 6: Categorias / Subcategorias ─────────────────────────────────────

model Category {
  id                String     @id @default(uuid())
  unidade_id        String
  parent_id         String?
  name              String     @db.VarChar(150)
  slug              String     @db.VarChar(160)
  description       String?    @db.Text
  image_url         String?    @db.VarChar(512)
  image_storage_key String?    @db.VarChar(512)
  sort_order        Int        @default(0)
  active            Boolean    @default(true)
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  unit     Unit       @relation(fields: [unidade_id], references: [id])
  parent   Category?  @relation("CategoryChildren", fields: [parent_id], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@map("categories")
}

// ─── Módulo 2: Fornecedores ───────────────────────────────────────────────────

enum TipoDocumentoSupplier {
  CNPJ
  CPF
}

model Supplier {
  id               String                @id @default(uuid())
  unidade_id       String
  document         String                @db.VarChar(14)
  document_type    TipoDocumentoSupplier
  razao_social     String                @db.VarChar(200)
  nome_fantasia    String?               @db.VarChar(200)
  email            String?               @db.VarChar(255)
  phone            String?               @db.VarChar(20)
  website          String?               @db.VarChar(512)
  logo_url         String?               @db.VarChar(512)
  logo_storage_key String?               @db.VarChar(512)
  active           Boolean               @default(true)
  notes            String?               @db.Text
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt

  unit        Unit              @relation(fields: [unidade_id], references: [id])
  addresses   SupplierAddress[]
  contacts    SupplierContact[]
  brands      SupplierBrand[]
  nf_entradas NfEntrada[]

  @@unique([unidade_id, document])
  @@map("suppliers")
}

model SupplierAddress {
  id          String   @id @default(uuid())
  supplier_id String
  label       String   @db.VarChar(50)
  cep         String   @db.VarChar(8)
  logradouro  String   @db.VarChar(200)
  numero      String   @db.VarChar(20)
  complemento String?  @db.VarChar(100)
  bairro      String   @db.VarChar(100)
  cidade      String   @db.VarChar(100)
  estado      String   @db.Char(2)
  created_at  DateTime @default(now())

  supplier Supplier @relation(fields: [supplier_id], references: [id])

  @@map("supplier_addresses")
}

model SupplierContact {
  id          String   @id @default(uuid())
  supplier_id String
  name        String   @db.VarChar(150)
  role        String?  @db.VarChar(100)
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(20)
  created_at  DateTime @default(now())

  supplier Supplier @relation(fields: [supplier_id], references: [id])

  @@map("supplier_contacts")
}

model SupplierBrand {
  supplier_id String
  brand_id    String

  supplier Supplier @relation(fields: [supplier_id], references: [id])
  brand    Brand    @relation(fields: [brand_id], references: [id])

  @@id([supplier_id, brand_id])
  @@map("supplier_brands")
}

// ─── Módulo 8: Centro de Custo ────────────────────────────────────────────────

enum TipoCusto {
  FIXO
  VARIAVEL
}

model CostCenter {
  id         String   @id @default(uuid())
  unidade_id String
  nome       String   @db.VarChar(120)
  descricao  String?  @db.Text
  ativo      Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  unit  Unit       @relation(fields: [unidade_id], references: [id])
  items CostItem[]

  @@map("cost_centers")
}

model CostItem {
  id             String    @id @default(uuid())
  cost_center_id String
  unidade_id     String
  nome           String    @db.VarChar(120)
  tipo           TipoCusto
  valor_centavos Int?
  percentual_bps Int?
  descricao      String?   @db.Text
  ativo          Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  cost_center CostCenter @relation(fields: [cost_center_id], references: [id])
  unit        Unit       @relation(fields: [unidade_id], references: [id])

  @@map("cost_items")
}

// ─── Módulo 7: Produtos ───────────────────────────────────────────────────────

enum MediaType {
  IMAGE
  VIDEO
}

model Product {
  id                String   @id @default(uuid())
  unidade_id        String
  category_id       String?
  brand_id          String?
  name              String   @db.VarChar(300)
  slug              String   @db.VarChar(320)
  sku               String?  @db.VarChar(100)
  barcode           String?  @db.VarChar(50)
  description       String?  @db.Text
  short_description String?  @db.VarChar(500)
  unit              String   @default("UN") @db.VarChar(10)
  active            Boolean  @default(true)
  featured          Boolean  @default(false)
  min_stock         Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  unit_rel         Unit             @relation("UnitProducts", fields: [unidade_id], references: [id])
  category         Category?        @relation(fields: [category_id], references: [id])
  brand            Brand?           @relation(fields: [brand_id], references: [id])
  pricing          ProductPricing?
  media            ProductMedia[]
  delivery         ProductDelivery?
  fiscal           ProductFiscal?
  seo              ProductSeo?
  lots             Lot[]
  stock_movements  StockMovement[]
  nf_entrada_items NfEntradaItem[]
  venda_items      VendaItem[]      @relation("ProductVendaItems")

  @@unique([unidade_id, slug])
  @@unique([unidade_id, sku])
  @@unique([unidade_id, barcode])
  @@map("products")
}

model ProductPricing {
  id                      String    @id @default(uuid())
  product_id              String    @unique
  cost_price_cents        Int       @default(0)
  sale_price_cents        Int       @default(0)
  promotional_price_cents Int?
  promotional_starts_at   DateTime?
  promotional_ends_at     DateTime?
  discount_enabled        Boolean   @default(false)
  max_discount_pct        Decimal?  @db.Decimal(5, 2)
  margin_pct              Decimal?  @db.Decimal(8, 4)
  margin_cents            Int?

  product Product @relation(fields: [product_id], references: [id])

  @@map("product_pricing")
}

model ProductMedia {
  id          String    @id @default(uuid())
  product_id  String
  storage_key String    @db.VarChar(512)
  url         String    @db.VarChar(512)
  media_type  MediaType
  alt_text    String?   @db.VarChar(255)
  sort_order  Int       @default(0)
  created_at  DateTime  @default(now())

  product Product @relation(fields: [product_id], references: [id])

  @@map("product_media")
}

model ProductDelivery {
  id               String   @id @default(uuid())
  product_id       String   @unique
  weight_grams     Int?
  height_cm        Decimal? @db.Decimal(8, 2)
  width_cm         Decimal? @db.Decimal(8, 2)
  depth_cm         Decimal? @db.Decimal(8, 2)
  free_shipping    Boolean  @default(false)
  ships_from_store Boolean  @default(true)

  product Product @relation(fields: [product_id], references: [id])

  @@map("product_delivery")
}

model ProductFiscal {
  id              String   @id @default(uuid())
  product_id      String   @unique
  ncm             String?  @db.VarChar(8)
  cfop            String?  @db.VarChar(5)
  cest            String?  @db.VarChar(7)
  origem          Int?
  cst_icms        String?  @db.VarChar(3)
  csosn           String?  @db.VarChar(3)
  cst_pis         String?  @db.VarChar(2)
  cst_cofins      String?  @db.VarChar(2)
  cst_ipi         String?  @db.VarChar(2)
  aliquota_icms   Decimal? @db.Decimal(5, 2)
  aliquota_pis    Decimal? @db.Decimal(5, 2)
  aliquota_cofins Decimal? @db.Decimal(5, 2)
  aliquota_ipi    Decimal? @db.Decimal(5, 2)

  product Product @relation(fields: [product_id], references: [id])

  @@map("product_fiscal")
}

model ProductSeo {
  id                      String    @id @default(uuid())
  product_id              String    @unique
  seo_title               String?   @db.VarChar(70)
  seo_description         String?   @db.VarChar(160)
  seo_keywords            String[]
  schema_org_json         Json?
  schema_org_generated_at DateTime?

  product Product @relation(fields: [product_id], references: [id])

  @@map("product_seo")
}

// ─── Módulo 4: Lotes ──────────────────────────────────────────────────────────

model Lot {
  id                String    @id @default(uuid())
  unidade_id        String
  product_id        String
  invoice_item_id   String?
  code              String    @db.VarChar(100)
  expires_at        DateTime? @db.Date
  manufactured_at   DateTime? @db.Date
  quantity_received Decimal   @db.Decimal(12, 3)
  tags              String[]
  active            Boolean   @default(true)
  notes             String?   @db.Text
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  unit             Unit            @relation(fields: [unidade_id], references: [id])
  product          Product         @relation(fields: [product_id], references: [id])
  invoice_item     NfEntradaItem?  @relation(fields: [invoice_item_id], references: [id])
  stock_movements  StockMovement[]

  @@unique([unidade_id, product_id, code])
  @@map("lots")
}

// ─── Módulo 18: Config Impostos ───────────────────────────────────────────────

enum TipoImposto {
  ISS
  ICMS
  IPI
  PIS
  COFINS
  DIFAL
  FCP
}

enum BaseCalculo {
  PRECO_VENDA
  PRECO_COMPRA
  VALOR_AGREGADO
}

enum TipoImpostoNcm {
  IPI
  PIS
  COFINS
  ICMS
}

model TaxProfile {
  id                String           @id @default(uuid())
  nome              String           @db.VarChar(100)
  regime_tributario RegimeTributario
  descricao         String?          @db.Text
  ativo             Boolean          @default(true)
  padrao            Boolean          @default(false)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  rates TaxRate[]

  @@map("tax_profiles")
}

model TaxRate {
  id                  String      @id @default(uuid())
  profile_id          String
  imposto             TipoImposto
  aliquota_percentual Int
  base_calculo        BaseCalculo
  incluso_no_preco    Boolean     @default(false)
  uf_origem           String?     @db.Char(2)
  uf_destino          String?     @db.Char(2)

  profile TaxProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("tax_rates")
}

model NcmTaxOverride {
  id                  String         @id @default(uuid())
  ncm                 String         @db.VarChar(8)
  imposto             TipoImpostoNcm
  aliquota_percentual Int
  descricao           String?        @db.VarChar(255)

  @@unique([ncm, imposto])
  @@map("ncm_tax_overrides")
}

// ─── Módulo 16: Config Pagamentos ─────────────────────────────────────────────

enum PaymentProviderSlug {
  ASAAS
  MERCADO_PAGO
  STRIPE
  PAGSEGURO
  PAYPAL
}

enum PaymentEnvironment {
  SANDBOX
  PRODUCAO
}

enum PaymentChannel {
  PDV
  ECOMMERCE
}

enum PaymentMethod {
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
  BOLETO
  DINHEIRO
  MAQUININHA_POINT
}

model PaymentProvider {
  id             String              @id @default(uuid())
  slug           PaymentProviderSlug @unique
  nome_exibicao  String              @db.VarChar(100)
  ativo          Boolean             @default(false)
  webhook_secret String?             @db.Text
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt

  credentials     PaymentProviderCredential[]
  channel_configs PaymentChannelConfig[]
  method_mappings PaymentMethodMapping[]

  @@map("payment_providers")
}

model PaymentProviderCredential {
  id          String             @id @default(uuid())
  provider_id String
  chave       String             @db.VarChar(100)
  valor       String             @db.Text
  ambiente    PaymentEnvironment

  provider PaymentProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@unique([provider_id, chave, ambiente])
  @@map("payment_provider_credentials")
}

model PaymentChannelConfig {
  id          String             @id @default(uuid())
  canal       PaymentChannel     @unique
  provider_id String
  ambiente    PaymentEnvironment
  updated_at  DateTime           @updatedAt

  provider PaymentProvider @relation(fields: [provider_id], references: [id])

  @@map("payment_channel_configs")
}

model PaymentMethodMapping {
  id                 String         @id @default(uuid())
  canal              PaymentChannel
  metodo             PaymentMethod
  provider_id        String
  ativo              Boolean        @default(true)
  taxa_percentual    Int            @default(0)
  taxa_fixa_centavos Int            @default(0)

  provider PaymentProvider @relation(fields: [provider_id], references: [id])

  @@unique([canal, metodo])
  @@map("payment_method_mappings")
}

model PaymentWebhookEvent {
  id           String              @id @default(uuid())
  provider     PaymentProviderSlug
  event_id     String              @db.VarChar(255)
  payload      Json
  processed    Boolean             @default(false)
  received_at  DateTime            @default(now())

  @@unique([provider, event_id])
  @@map("payment_webhook_events")
}

// ─── Módulo 5: Estoque ────────────────────────────────────────────────────────

enum StockMovementType {
  PURCHASE_ENTRY
  PURCHASE_CANCEL
  SALE_OUT
  SALE_RETURN
  MANUAL_ENTRY
  MANUAL_EXIT
  TRANSFER_OUT
  TRANSFER_IN
}

model StockMovement {
  id              String            @id @default(uuid())
  unidade_id      String
  product_id      String
  lot_id          String
  type            StockMovementType
  quantity        Decimal           @db.Decimal(12, 3)
  reference_id    String?
  reference_type  String?           @db.VarChar(50)
  idempotency_key String?           @unique @db.VarChar(255)
  notes           String?           @db.Text
  created_by      String
  created_at      DateTime          @default(now())

  unit    Unit    @relation(fields: [unidade_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])
  lot     Lot     @relation(fields: [lot_id], references: [id])

  @@index([unidade_id, product_id, lot_id])
  @@index([unidade_id, product_id])
  @@map("stock_movements")
}

// ─── Módulo 22: LGPD ─────────────────────────────────────────────────────────

enum LgpdRequestType {
  EXPORTACAO
  EXCLUSAO
  RETIFICACAO
  REVOGACAO_CONSENTIMENTO
}

enum LgpdRequestStatus {
  PENDENTE
  EM_PROCESSAMENTO
  CONCLUIDA
  REJEITADA
}

// ─── Módulo 12: Clientes ──────────────────────────────────────────────────────

enum CustomerFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTISELECT
  BOOLEAN
  PHONE
  EMAIL
  CPF_CNPJ
}

enum CustomerAuditAction {
  CRIACAO
  LEITURA
  ATUALIZACAO
  EXCLUSAO
  EXPORTACAO
}

model CustomerFieldDefinition {
  id               String            @id @default(uuid())
  unidade_id       String
  nome_campo       String            @db.VarChar(60)
  label            String            @db.VarChar(120)
  tipo             CustomerFieldType
  obrigatorio      Boolean           @default(false)
  validacao_regex  String?           @db.VarChar(500)
  opcoes           Json?
  ordem            Int
  ativo            Boolean           @default(true)
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  unit Unit @relation(fields: [unidade_id], references: [id])

  @@unique([unidade_id, nome_campo])
  @@unique([unidade_id, ordem])
  @@map("customer_field_definitions")
}

model Customer {
  id                    String    @id @default(uuid())
  unidade_id            String
  nome                  String    @db.VarChar(255)
  telefone_principal    String    @db.VarChar(20)
  email                 String?   @db.VarChar(255)
  cpf_cnpj_enc          String?   @db.Text
  cpf_cnpj_hash         String?   @db.VarChar(64)
  data_nascimento_enc   String?   @db.Text
  dados_dinamicos       Json?
  consentimento_lgpd    Boolean   @default(false)
  consentimento_versao  String?   @db.VarChar(20)
  consentimento_em      DateTime?
  ativo                 Boolean   @default(true)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  unit          Unit                @relation(fields: [unidade_id], references: [id])
  audit_logs    CustomerAuditLog[]
  lgpd_requests LgpdDataRequest[]   @relation("CustomerLgpdRequests")
  vendas        Venda[]             @relation("CustomerVendas")

  @@index([unidade_id])
  @@index([cpf_cnpj_hash])
  @@map("customers")
}

model CustomerAuditLog {
  id          String              @id @default(uuid())
  customer_id String
  acao        CustomerAuditAction
  usuario_id  String
  ip_origem   String?             @db.VarChar(45)
  detalhe     String?             @db.Text
  created_at  DateTime            @default(now())

  customer Customer @relation(fields: [customer_id], references: [id])

  @@index([customer_id])
  @@map("customer_audit_logs")
}

model LgpdDataRequest {
  id               String            @id @default(uuid())
  unidade_id       String
  customer_id      String
  tipo             LgpdRequestType
  status           LgpdRequestStatus @default(PENDENTE)
  descricao        String?           @db.Text
  solicitado_em    DateTime          @default(now())
  prazo_legal      DateTime
  processado_em    DateTime?
  processado_por   String?
  justificativa    String?           @db.Text
  dados_exportados Json?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  unit     Unit     @relation("UnitLgpdRequests", fields: [unidade_id], references: [id])
  customer Customer @relation("CustomerLgpdRequests", fields: [customer_id], references: [id])

  @@index([unidade_id, status])
  @@index([customer_id])
  @@map("lgpd_data_requests")
}

// ─── Módulo 3: Notas Fiscais de Entrada ───────────────────────────────────────

enum NfEntradaStatus {
  RASCUNHO
  CONFIRMADA
  CANCELADA
}

model NfEntrada {
  id            String          @id @default(uuid())
  unidade_id    String
  fornecedor_id String?
  numero        String          @db.VarChar(10)
  serie         String?         @db.VarChar(3)
  chave_acesso  String?         @db.Char(44)
  data_emissao  DateTime        @db.Date
  data_entrada  DateTime?       @db.Date
  valor_total   Int
  status        NfEntradaStatus @default(RASCUNHO)
  xml_url       String?
  pdf_url       String?
  observacao    String?         @db.Text
  created_by    String
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt

  unidade    Unit            @relation(fields: [unidade_id], references: [id])
  fornecedor Supplier?       @relation(fields: [fornecedor_id], references: [id])
  items      NfEntradaItem[]

  @@unique([unidade_id, chave_acesso])
  @@index([unidade_id, status])
  @@index([fornecedor_id])
  @@map("nf_entradas")
}

model NfEntradaItem {
  id              String    @id @default(uuid())
  nf_entrada_id   String
  numero_item     Int
  codigo_produto  String?   @db.VarChar(60)
  ean             String?   @db.VarChar(14)
  descricao       String    @db.VarChar(500)
  ncm             String?   @db.VarChar(8)
  cfop            String?   @db.VarChar(4)
  unidade_medida  String?   @db.VarChar(6)
  quantidade      Decimal   @db.Decimal(12, 3)
  valor_unitario  Int
  valor_total     Int
  lote_numero     String?   @db.VarChar(100)
  data_validade   DateTime? @db.Date
  data_fabricacao DateTime? @db.Date
  product_id      String?
  brand_id        String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  nf_entrada NfEntrada @relation(fields: [nf_entrada_id], references: [id], onDelete: Cascade)
  product    Product?  @relation(fields: [product_id], references: [id])
  brand      Brand?    @relation(fields: [brand_id], references: [id])
  lots       Lot[]

  @@index([nf_entrada_id])
  @@index([product_id])
  @@map("nf_entrada_items")
}

// ─── Módulo 28: Vendas (PDV) ──────────────────────────────────────────────────

enum VendaStatus {
  ABERTA
  FINALIZADA
  CANCELADA
}

enum VendaOrigem {
  PDV
  ECOMMERCE
  PDV_OFFLINE
}

enum VendaPaymentStatus {
  PENDENTE
  PAGO
  CANCELADO
}

model Venda {
  id                      String      @id @default(uuid())
  unidade_id              String
  numero                  Int         @default(autoincrement())
  status                  VendaStatus @default(ABERTA)
  origem                  VendaOrigem @default(PDV)
  cliente_id              String?
  desconto_total_centavos Int         @default(0)
  total_bruto_centavos    Int         @default(0)
  total_liquido_centavos  Int         @default(0)
  observacao              String?     @db.Text
  created_by              String
  finalizada_em           DateTime?
  cancelada_em            DateTime?
  sync_id                 String?     @unique @db.VarChar(100)
  created_at              DateTime    @default(now())
  updated_at              DateTime    @updatedAt

  unit     Unit           @relation(fields: [unidade_id], references: [id])
  cliente  Customer?      @relation("CustomerVendas", fields: [cliente_id], references: [id])
  items    VendaItem[]
  payments VendaPayment[]

  @@index([unidade_id, status])
  @@index([unidade_id, created_at])
  @@index([cliente_id])
  @@map("vendas")
}

model VendaItem {
  id                      String   @id @default(uuid())
  venda_id                String
  product_id              String
  numero_item             Int
  quantidade              Decimal  @db.Decimal(12, 3)
  preco_unitario_centavos Int
  desconto_item_centavos  Int      @default(0)
  total_centavos          Int
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  venda   Venda   @relation(fields: [venda_id], references: [id], onDelete: Cascade)
  product Product @relation("ProductVendaItems", fields: [product_id], references: [id])

  @@index([venda_id])
  @@index([product_id])
  @@map("venda_items")
}

model VendaPayment {
  id                      String             @id @default(uuid())
  venda_id                String
  metodo                  PaymentMethod
  valor_centavos          Int
  status                  VendaPaymentStatus @default(PENDENTE)
  troco_centavos          Int                @default(0)
  provider_transaction_id String?            @db.VarChar(255)
  pago_em                 DateTime?
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt

  venda Venda @relation(fields: [venda_id], references: [id], onDelete: Cascade)

  @@index([venda_id])
  @@map("venda_payments")
}
